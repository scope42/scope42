{
  "name": "@scope42/data",
  "version": "0.0.0",
  "license": "GPL-3.0-only",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/node.mjs",
      "require": "./dist/node.js",
      "types": "./dist/node.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      ".": ["./dist/index.d.ts"],
      "node": ["./dist/node.d.ts"]
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint \"src/**/*.ts*\"",
    "test": "jest"
  },
  "tsup": {
    "entry": {
      "index": "src/index.ts",
      "node": "src/io/adapters/node.ts",
      "fsa": "src/io/adapters/fsa.ts"
    },
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true,
    "clean": true
  },
  "prettier": "@xinra/prettier-config",
  "devDependencies": {
    "@scope42/tsconfig": "*",
    "@types/jest": "29.4.0",
    "@types/picomatch": "^3.0.2",
    "@xinra/prettier-config": "2.0.0",
    "eslint": "8.35.0",
    "eslint-config-scope42": "*",
    "jest": "29.5.0",
    "prettier": "2.8.8",
    "ts-jest": "29.0.5",
    "tsup": "6.6.3",
    "typescript": "4.9.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "picomatch": "^4.0.4",
    "yaml": "^2.1.3",
    "zod": "^3.19.1"
  }
}
